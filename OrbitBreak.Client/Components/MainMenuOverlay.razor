<div class="menu-overlay">
    <div class="menu-logo">ORBIT BREAK</div>
    @if (LoggedInUser != null)
    {
        <p class="menu-greeting">Welcome back, <span>@LoggedInUser</span>!</p>
    }
    else
    {
        <p class="menu-sub">Slingshot the ball around gravity wells. Chain wells for combo multipliers.</p>
    }
    <span class="menu-tip-wrap">
        <span class="menu-hint-chip">ⓘ How to play</span>
        <span class="menu-tip">Drag upward from the paddle to aim, release to launch the ball. Move the paddle with <b>A/D</b> or <b>←/→</b> to bounce it back. Chain gravity wells for combo multipliers. <b>Esc</b> quits a run.</span>
    </span>
    <div class="menu-buttons">
        <span class="menu-tip-wrap">
            <button class="btn-normal" @onclick="() => OnStart.InvokeAsync(GameMode.Normal)">Start Game</button>
            <span class="menu-tip"><b>Normal</b> — three balls, clear the blocks before you run out.</span>
        </span>
        <span class="menu-tip-wrap">
            <button @onclick="() => OnStart.InvokeAsync(GameMode.Zen)">Zen Mode</button>
            <span class="menu-tip"><b>Zen</b> — endless. Nothing ends the run; relax and chain combos.</span>
        </span>
        <span class="menu-tip-wrap">
            <button @onclick="() => OnStart.InvokeAsync(GameMode.TimeAttack)">Time Attack</button>
            <span class="menu-tip"><b>Time Attack</b> — 60-second sprint. Break as many blocks as you can.</span>
        </span>
        <span class="menu-tip-wrap">
            <button @onclick="OnLeaderboard">Leaderboard</button>
            <span class="menu-tip">Top scores across every player.</span>
        </span>
    </div>
    @if (LoggedInUser != null)
    {
        <div class="signed-in-badge"><span class="signed-in-dot"></span>Signed in as <b>@LoggedInUser</b></div>
    }
    else
    {
        <p class="menu-sub" style="font-size:0.85rem;color:#64748b">Sign in at the portal to save scores</p>
    }
    @if (HighScore > 0)
    {
        <p class="menu-best">Best score: @HighScore.ToString("N0")</p>
    }
</div>

@code {
    [Parameter] public string? LoggedInUser { get; set; }
    [Parameter] public int HighScore { get; set; }
    [Parameter] public EventCallback<GameMode> OnStart { get; set; }
    [Parameter] public EventCallback OnLeaderboard { get; set; }
}
